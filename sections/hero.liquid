<div class="hero-banner">
  {{ section.settings.image | img_tag: section.settings.heading }}
  <h1 class="hero-heading">{{ section.settings.heading }}</h1>
</div>

{% schema %}
{
    "name":"Hero",
    "tag":"section",
    "settings":[
        {
            "type":"text",
            "id":"heading",
            "label":"Heading"
        },
        {
            "type":"image_picker",
            "id":"image",
            "label":"Image"
        }
    ],
  "presets": [
    {
      "name": "Default",
      "category": "Hero"
    }
  ]
}

{% endschema %}